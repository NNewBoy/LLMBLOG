# LLMBLOG 后端环境变量
# 复制为 .env 并按需修改

# JWT 签名密钥（生产环境必须修改为长随机字符串）
SECRET_KEY=change-me-to-a-long-random-string

# 管理员密码哈希（前端 SHA256 预哈希后的值）
# 留空则首次启动用明文 admin 初始化并打印
ADMIN_PASSWORD_HASH=

# SQLite 数据库文件路径
DB_PATH=app/data/app.db

# 图片上传目录
UPLOAD_DIR=uploads

# CORS 允许来源（逗号分隔，生产环境设为实际域名）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=120
